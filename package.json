{
  "name": "takeout-free",
  "version": "0.0.1",
  "private": true,
  "resolutions": {
    "sharp": "npm:@tamagui/proxy-worm@1.123.14",
    "expo-modules-core": "55.0.16",
    "expo-constants": "55.0.9",
    "expo-linking": "55.0.8",
    "@react-navigation/native": "7.2.2",
    "react-native-reanimated": "4.3.0"
  },
  "sideEffects": false,
  "type": "module",
  "files": [],
  "engines": {
    "node": "24.3.0"
  },
  "packageManager": "bun@1.3.9",
  "scripts": {
    "android": "one run:android",
    "backend:clean": "docker compose down --volumes --remove-orphans --rmi local",
    "backend": "bun run migrate:build && docker compose up --remove-orphans",
    "build": "one build",
    "check": "tko check",
    "check:all": "tko check --all",
    "postinstall": "bun run ./scripts/postinstall.ts",
    "ci": "NODE_ENV=production dotenvx run -f .env .env.production -- bun scripts/ci/release.ts",
    "clean": "rm -rf dist .expo",
    "dev": "one dev",
    "env:dev": "NODE_ENV=development dotenvx run -f .env .env.development --",
    "env:test": "NODE_ENV=test dotenvx run -f .env .env.development --",
    "env:update": "tko run env-update",
    "ios": "one run:ios",
    "format:check": "oxfmt --check",
    "format": "oxfmt",
    "lint:fix": "oxfmt && oxlint --import-plugin --type-aware --fix --fix-suggestions",
    "lint": "oxlint --import-plugin --type-aware",
    "migrate": "bun run env:dev bun ./src/database/migrate.ts",
    "migrate:build": "tko migrate build",
    "prebuild:native": "one prebuild",
    "run:dev": "bun env:dev bun",
    "run:prod": "NODE_ENV=production dotenvx run -f .env .env.production -- bun",
    "run:test": "bun env:test bun",
    "test:integration": "bun run env:dev bun --cwd=./src/test playwright test",
    "test:unit": "bun run:dev vitest run -c ./src/test/vitest.config.ts",
    "test": "bun run test:unit && bun run test:integration",
    "up": "tko up",
    "zero:generate": "on-zero generate --after 'bun lint:fix'"
  },
  "overrides": {
    "@expo/fingerprint": "0.15.3",
    "sharp": "npm:@tamagui/proxy-worm@1.123.14",
    "expo-modules-core": "55.0.16",
    "expo-constants": "55.0.9",
    "expo-linking": "55.0.8",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-native": "0.83.2",
    "@react-navigation/native": "7.2.2",
    "react-native-reanimated": "4.3.0"
  },
  "dependencies": {
    "@better-auth/expo": "^1.3.32",
    "@better-fetch/fetch": "^1.1.18",
    "@gorhom/bottom-sheet": "^5.2.6",
    "@react-native-masked-view/masked-view": "^0.3.2",
    "@react-native-menu/menu": "^2.0.0",
    "@rocicorp/zero": "0.26.2",
    "@take-out/better-auth-utils": "^0.2.10",
    "@take-out/cli": "^0.2.10",
    "@take-out/helpers": "^0.2.10",
    "@take-out/hooks": "^0.2.10",
    "@take-out/postgres": "^0.2.10",
    "@take-out/scripts": "^0.2.10",
    "@tamagui/config": "2.0.0-rc.34",
    "@tamagui/constants": "2.0.0-rc.34",
    "@tamagui/helpers-icon": "2.0.0-rc.34",
    "@tamagui/linear-gradient": "2.0.0-rc.34",
    "@tamagui/native": "2.0.0-rc.34",
    "@tamagui/themes": "2.0.0-rc.34",
    "@tamagui/toast": "2.0.0-rc.34",
    "@tamagui/vite-plugin": "2.0.0-rc.34",
    "@vxrn/color-scheme": "1.14.2",
    "@vxrn/compiler": "1.14.2",
    "@vxrn/resolve": "1.14.2",
    "@vxrn/tslib-lite": "1.14.2",
    "@vxrn/use-isomorphic-layout-effect": "1.14.2",
    "@vxrn/vite-plugin-metro": "1.14.2",
    "better-auth": "^1.3.32",
    "burnt": "^0.12.2",
    "drizzle-orm": "1.0.0-beta.9-e89174b",
    "expo": "~55.0.6",
    "expo-blur": "~55.0.10",
    "expo-build-properties": "~55.0.10",
    "expo-clipboard": "~55.0.9",
    "expo-constants": "55.0.9",
    "expo-crypto": "~55.0.10",
    "expo-font": "~55.0.4",
    "expo-haptics": "~55.0.9",
    "expo-image": "~55.0.6",
    "expo-linking": "55.0.8",
    "expo-linear-gradient": "~55.0.9",
    "expo-splash-screen": "~55.0.12",
    "expo-sqlite": "^55.0.11",
    "expo-web-browser": "~55.0.10",
    "motion": "12.36.0",
    "on-zero": "0.2.10",
    "one": "1.14.2",
    "pg": "8.18.0",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-native": "0.83.2",
    "react-native-bottom-tabs": "^0.10.0",
    "react-native-gesture-handler": "~2.30.0",
    "react-native-ios-context-menu": "^3.2.1",
    "react-native-ios-utilities": "^5.2.0",
    "react-native-keyboard-controller": "1.20.7",
    "react-native-mmkv": "^3.3.0",
    "react-native-permissions": "^5.4.2",
    "react-native-reanimated": "^4.3.0",
    "react-native-safe-area-context": "~5.6.2",
    "react-native-screens": "~4.23.0",
    "react-native-svg": "15.15.3",
    "react-native-worklets": "^0.8.0",
    "rolldown": "^1.0.0-rc.12",
    "tamagui": "2.0.0-rc.34",
    "valibot": "^1.1.0",
    "vxrn": "1.14.2",
    "zeego": "^3.0.6"
  },
  "devDependencies": {
    "@dotenvx/dotenvx": "^1.44.1",
    "@playwright/test": "^1.55.0",
    "@types/bun": "^1.2.16",
    "@types/node": "24.0.3",
    "@types/pg": "^8.11.10",
    "@types/react": "19.2.14",
    "@types/react-dom": "~19.1.7",
    "drizzle-kit": "1.0.0-beta.9-e89174b",
    "oxfmt": "^0.16.0",
    "oxlint": "^1.31.0",
    "oxlint-tsgolint": "^0.11.4",
    "playwright": "^1.57.0",
    "rollup-plugin-visualizer": "^6.0.5",
    "typescript": "^5.9.3",
    "vite": "8.0.3",
    "vitest": "4.1.0"
  },
  "reanimated": {
    "staticFeatureFlags": {
      "ENABLE_SHARED_ELEMENT_TRANSITIONS": false,
      "ANDROID_SYNCHRONOUSLY_UPDATE_UI_PROPS": true,
      "IOS_SYNCHRONOUSLY_UPDATE_UI_PROPS": true,
      "USE_COMMIT_HOOK_ONLY_FOR_REACT_COMMITS": true,
      "DISABLE_COMMIT_PAUSING_MECHANISM": true,
      "FORCE_REACT_RENDER_FOR_SETTLED_ANIMATIONS": true
    }
  },
  "trustedDependencies": [
    "@rocicorp/zero-sqlite3",
    "oxc-parser"
  ],
  "env": {
    "BETTER_AUTH_SECRET": true,
    "BETTER_AUTH_URL": true,
    "ONE_SERVER_URL": true,
    "VITE_ZERO_HOSTNAME": "",
    "VITE_WEB_HOSTNAME": "",
    "ZERO_VERSION": "$dep:@rocicorp/zero",
    "ZERO_NUM_SYNC_WORKERS": "2",
    "ZERO_CVR_MAX_CONNS": "4",
    "ZERO_UPSTREAM_MAX_CONNS": "8",
    "ZERO_PER_USER_MUTATION_LIMIT_MAX": "30",
    "ZERO_PER_USER_MUTATION_LIMIT_WINDOW_MS": "60000",
    "ZERO_MUTATE_FORWARD_COOKIES": "true",
    "ZERO_QUERY_FORWARD_COOKIES": "true",
    "ZERO_APP_PUBLICATIONS": "zero_takeout"
  },
  "upgradeSets": {
    "takeout": [
      "@take-out/*",
      "on-zero"
    ],
    "tamagui": [
      "tamagui",
      "@tamagui/*"
    ],
    "one": [
      "one",
      "vxrn",
      "@vxrn/*"
    ],
    "zero": [
      "@rocicorp/zero"
    ],
    "better-auth": [
      "better-auth",
      "@better-auth/*"
    ],
    "drizzle": [
      "drizzle-orm",
      "drizzle-kit"
    ]
  },
  "publishConfig": {
    "access": "public"
  }
}
